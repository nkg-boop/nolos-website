# Environment variables for the Nolos Nanny Placement site.
#
# For LOCAL development: copy this file to .env, fill in real values, and
# run `vercel dev` (see README). vercel dev also automatically pulls your
# actual Development environment variables from the linked Vercel project,
# so a fully-filled .env is a convenience for offline work, not strictly
# required once the project is linked.
#
# For DEPLOYMENT: set every one of these in the Vercel dashboard under
# Project Settings → Environment Variables. Never commit real values.

# --- Upstash Redis (storage + rate limiting) ---
# These are set AUTOMATICALLY once you install the Upstash Redis
# integration from the Vercel Marketplace and connect it to this project —
# you should not need to type these in by hand. See README for the exact
# steps. Listed here so you know what to expect / can verify they exist.
UPSTASH_REDIS_REST_URL=set-automatically-by-the-vercel-upstash-integration
UPSTASH_REDIS_REST_TOKEN=set-automatically-by-the-vercel-upstash-integration

# --- Admin session signing ---
# Used to sign the admin login cookie (HMAC-SHA256). Generate a real one with:
#   npm run gen-secret
# Do not reuse this example value, and use a DIFFERENT value than
# ENQUIRY_ENCRYPTION_KEY below — these protect different things and
# reusing one secret for both narrows what an attacker needs to compromise
# to break both protections at once.
SESSION_SECRET=replace-this-with-a-real-64-character-hex-string

# --- Admin login credentials ---
ADMIN_USERNAME=replace-this
# Bcrypt hash of the admin password — NEVER the plaintext password itself.
# Generate one with:
#   npm run gen-password-hash
# (this prompts interactively and never writes the plaintext anywhere)
ADMIN_PASSWORD_HASH=replace-this-with-a-bcrypt-hash

# --- Enquiry data encryption ---
# 32-byte hex key used to encrypt enquiry data at rest in Redis
# (AES-256-GCM). Generate a real one with:
#   npm run gen-secret
# If this is lost, previously stored enquiries cannot be decrypted — back
# it up somewhere safe and SEPARATE from Redis itself (a password manager
# or secrets vault), never alongside the data it protects.
ENQUIRY_ENCRYPTION_KEY=replace-this-with-a-real-64-character-hex-string

# --- Environment flag ---
# Vercel sets NODE_ENV=production automatically on real deployments — you
# generally do not need to set this yourself except for local testing.
# It controls whether the Secure cookie flag is set (requires HTTPS to
# function; browsers silently drop Secure cookies over plain http://,
# which is why this is conditional rather than always-on).
NODE_ENV=development
